    "express-async-errors": "^3.1.1",
    "fuse.js": "^7.0.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "node-fetch": "^3.3.2",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
