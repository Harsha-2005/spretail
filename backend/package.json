  "description": "Shared Expenses App Backend",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "dev": "nodemon src/index.js",
    "start": "node src/index.js",
    "build": "PRISMA_SKIP_DATABASE_URL_VALIDATION=true npx prisma generate",
